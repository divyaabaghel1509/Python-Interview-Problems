        "def find_common_elements(list1,list2):\n",
        "  commmon_elements = []\n",
        "  for elt in list1:\n",
        "    if elt in list2:\n",
        "      commmon_elements.append(elt)\n",
        "  return commmon_elements\n",
        "\n",
        "list_a = [1, 2, 3, 4, 5]\n",
        "list_b = [4, 5, 6, 7, 8]\n",
        "common = find_common_elements(list_a, list_b)\n",
        "print(common)"
      ]
