      ],
      "source": [
        "def check_prime(num):\n",
        "    if num < 2:\n",
        "        return f\"{num} is not a prime number\"\n",
        "\n",
        "    for i in range(2, num):\n",
        "        if num % i == 0:\n",
        "            return f\"{num} is not a prime number\"\n",
        "\n",
        "    return f\"{num} is a prime number\"\n",
        "\n",
        "print(check_prime(9))"
      ]
    },
